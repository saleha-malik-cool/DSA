# include <iostream>
 # include <vector>
 using namespace std;
 int missing(vector<int>&arr){
int n = arr.size();
int xor1=0,xor2=0;
 for(int i =0;i<n; i++ ){
    xor1^=arr[i];
    xor2^=i;
 } 
xor2^=n;
return xor1^xor2;  }
int main(){
    vector<int>arr={0,1,2,4,5,3,7};
    cout<<missing(arr);
}
