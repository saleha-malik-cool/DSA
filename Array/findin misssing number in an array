 using namespace std;
 int missing(vector<int>&arr){
int n = arr.size();
int sum1 =0;
for(int i =0; i<n; i++){
    sum1 = sum1+arr[i];
}
int sum=(n*(n+1))/2;
    

int ans = sum-sum1;
return ans;
}
int main(){
    vector<int> arr={0,1,2,4};
    cout<<missing(arr);
}


