#include <iostream>
#include <vector>
# include <unordered_set>

using namespace std;
 void markrow(vector<vector<int>>&arr, int i){
    
    int m = arr[0].size();

    for (int j=0; j<m; j++){
        if(arr[i][j]!=0){
            arr[i][j]=-1;
        }
    }}
    void markcol(vector<vector<int>>&arr, int j){
        int n = arr.size();
         
         for (int i =0; i<n; i++){
            if(arr[i][j]!=0){
                arr[i][j]=-1;
            }
         }
    }

void matrix(vector<vector<int>> &arr){
    int n = arr.size();
    int m = arr[0].size();
    for(int i =0; i<n; i++){
         for(int j =0; j<m; j++){
            if(arr[i][j]==0){
                markrow(arr,i);
                markcol(arr,j);
            }
         }}
        for(int i =0; i<n; i++){
            for(int j =0; j<m; j++){
                if (arr[i][j]==-1){
                    arr[i][j]=0;
                }
            }
        }}





int main(){
    vector<vector<int>>arr={{1,1,1},{1,0,1},{1,1,1}};
     matrix(arr);
    for(int i =0; i<arr.size();i++){
        for(int j =0; j<arr[0].size(); j++){
            cout<<arr[i][j]<<" ";
        }
        cout<<endl;
    }

}

