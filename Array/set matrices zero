                row[i]=1;
                col[j]=1;
            }
        }
    }
    for(int i =0; i<n; i++){
        for(int j =0; j<m; j++){
            if ((row[i]|| col[j])==1){
                arr[i][j]=0;
            }

        }
    }
 }
