// Brute force
# include <iostream>
# include <vector>
using namespace std;
int leftrotate(vector <int>& arr, int n, int d ){
    int temp[d];
    for (int i= 0; i<d; i++){
        temp [i] = arr[i];
        

    }
    for ( int k = d; k<n; k++){
        arr[k-d] = arr[k];

    }
    for ( int i = n-d; i<n;i++){
        arr[i] = temp [ i-(n-d)];
    }


    
 
}
int main(){
    vector <int>arr = {1,2,3,4,5,6,7};
