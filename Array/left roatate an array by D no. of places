// optimized
# include <iostream>
# include <vector>
using namespace std;
void reverse(vector<int>&arr, int start, int end){
    
     while(start<=end){
        int temp = arr[start];
        arr[start ]= arr[ end];
        arr[end]= temp;
        start++, end--;
     }

}

void leftrotate(vector <int>& arr, int n, int d ){
    d=d%n;
    reverse(arr,0, d-1);
    reverse(arr,d, n-1);
    reverse(arr,0,n-1);

}
int main(){
    int n;
    cin>>n;
    vector <int> arr(n);
    for(int i =0; i<n; i++){
        cin >> arr[i];
    }
    int d; 
    cin>>d;
 leftrotate(arr, n, d);
    for(int i =0; i<n; i++){
        cout<< arr[i]<<" ";
    }

}






