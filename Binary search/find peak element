mid ko dekh lo ki aage wale se bada h ya nhi phir agar h to start ko mid+1 karke number ko eliminate 
kardo and elze mid=end kardo

class Solution {
public:
    int findPeakElement(vector<int>& nums) {
        int start =0; 
        int end = nums.size()-1;
        while(start<end){
            int mid = start+(end - start)/2;
            if (nums[mid]<nums[mid+1]){
                start = mid+1;
            }
            else{
                end = mid;
            }
        }
        return end;
    }
};
