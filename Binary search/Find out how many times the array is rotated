Given an integer array nums of size n, sorted in ascending order with distinct values. The array has been right rotated 
an unknown number of times, between 0 and n-1 (including). Determine the number of 
rotations performed on the array.



class Solution {
public:
    int findKRotation(vector<int> &nums)  {
        int start = 0;
        int end = nums.size()-1;
        while(start<end){
            int mid= start +(end - start)/2;
            if (nums[mid]>nums[end]){
                start =mid +1;

            }
            else{
                end = mid;
            }
        }
        return end;
    }
};
