//Given a sorted array nums and an integer x. Find the floor and ceil of x in nums. The floor of x is the largest 
element in the array which is smaller than or equal to x. The ceiling of x is the smallest element in the array 
greater than or equal to x. If no floor or ceil exists, output -1.

class Solution {
public:
    vector<int> getFloorAndCeil(vector<int> nums, int x) {

        int start =0; 
        int end = nums.size()-1;

   int floor=-1;
   int ceil=-1;
   int mid;
   while(start<=end){
    mid = start+(end-start)/2;
    if(nums[mid]>x){
        ceil= nums[mid];
        end= mid-1;

    }
    else if(nums[mid]<x){
        floor= nums[mid];
        start = mid+1;
    }
    else{
        return {x,x};
    }
    
   }
return {floor ,ceil};
    }
};
